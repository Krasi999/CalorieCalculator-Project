<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalorieCalculator.Views.MainView.Meal.MealDetailPage"
             x:Name="ThisPage"
             BackgroundColor="#1A1A2E"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" Padding="20,50,20,10" ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0"
                    Text="←"
                    FontSize="24"
                    BackgroundColor="Transparent"
                    TextColor="White"
                    Command="{Binding GoBackCommand}"/>

            <Label Grid.Column="1"
                   Text="{Binding MealName}"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="White"
                   VerticalOptions="Center"/>

            <!-- Add more food button -->
            <Label Grid.Column="2"
                   Text="+"
                   FontSize="28"
                   TextColor="#4DB6AC"
                   VerticalOptions="Center"
                   Margin="0,0,10,0">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding AddMoreFoodCommand}"/>
                </Label.GestureRecognizers>
            </Label>
        </Grid>

        <!-- Summary -->
        <Frame Grid.Row="1"
               Margin="20,5,20,10"
               Padding="15"
               CornerRadius="15"
               BackgroundColor="#2D2D44"
               HasShadow="False"
               BorderColor="Transparent">
            <Grid ColumnDefinitions="*,*,*,*">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="3">
                    <Label Text="{Binding TotalCalories}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#4DB6AC"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="kcal"
                           FontSize="11"
                           TextColor="#888"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="3">
                    <Label Text="{Binding TotalProtein, StringFormat='{0:F1}'}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Протеин"
                           FontSize="11"
                           TextColor="#888"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="3">
                    <Label Text="{Binding TotalCarbs, StringFormat='{0:F1}'}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Въглех."
                           FontSize="11"
                           TextColor="#888"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="3">
                    <Label Text="{Binding TotalFats, StringFormat='{0:F1}'}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Мазнини"
                           FontSize="11"
                           TextColor="#888"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Frame>

        <!-- Food List -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Foods}"
                        Margin="10,0">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="10"
                                     Padding="20">
                    <Label Text="Няма добавени храни"
                           FontSize="18"
                           TextColor="#888"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="Натиснете + за да добавите"
                           FontSize="14"
                           TextColor="#555"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="#2D2D44"
                           CornerRadius="12"
                           Padding="15"
                           Margin="10,5"
                           HasShadow="False"
                           BorderColor="Transparent">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto">

                            <!-- Product Name and Calories -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding ProductName}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"/>

                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Calories, StringFormat='{0} kcal'}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#4DB6AC"
                                   VerticalOptions="Center"/>

                            <!-- Macros -->
                            <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                   FontSize="12"
                                   TextColor="#888"
                                   Margin="0,4,0,0">
                                <Label.Text>
                                    <MultiBinding StringFormat="P: {0:F1}g  C: {1:F1}g  F: {2:F1}g  |  {3}g">
                                        <Binding Path="Protein"/>
                                        <Binding Path="Carbs"/>
                                        <Binding Path="Fats"/>
                                        <Binding Path="Weight"/>
                                    </MultiBinding>
                                </Label.Text>
                            </Label>

                            <!-- Action Buttons -->
                            <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Spacing="15"
                                                   Margin="0,10,0,0">

                                <!-- Edit Weight -->
                                <Frame BackgroundColor="#3D3D54"
                                       CornerRadius="8"
                                       Padding="12,6"
                                       HasShadow="False"
                                       BorderColor="Transparent">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="✏️" FontSize="14" VerticalOptions="Center"/>
                                        <Label Text="Промени грамаж"
                                               FontSize="12"
                                               TextColor="White"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.EditWeightCommand, Source={x:Reference ThisPage}}"
                                            CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>
                                </Frame>

                                <!-- Delete -->
                                <Frame BackgroundColor="#4A2030"
                                       CornerRadius="8"
                                       Padding="12,6"
                                       HasShadow="False"
                                       BorderColor="Transparent">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="🗑️" FontSize="14" VerticalOptions="Center"/>
                                        <Label Text="Изтрий"
                                               FontSize="12"
                                               TextColor="#FF6B6B"
                                               VerticalOptions="Center"/>
                                    </HorizontalStackLayout>
                                    <Frame.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding BindingContext.DeleteFoodCommand, Source={x:Reference ThisPage}}"
                                            CommandParameter="{Binding .}"/>
                                    </Frame.GestureRecognizers>
                                </Frame>

                            </HorizontalStackLayout>

                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>