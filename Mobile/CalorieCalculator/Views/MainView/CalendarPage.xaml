<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CalorieCalculator.ViewModels"
             xmlns:components="clr-namespace:CalorieCalculator.Views.MainView.Components"
             x:Class="CalorieCalculator.Views.CalendarPage"
             x:DataType="vm:CalendarViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="12" Padding="16,20">

                <Label Text="Календар"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#1E293B"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,5" />

                <!-- Календар -->
                <Border StrokeShape="RoundRectangle 16"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">

                        <!-- Навигация месец -->
                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="◀"
                                   FontSize="20" TextColor="#64748B"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PreviousMonthCommand}" />
                                </Label.GestureRecognizers>
                            </Label>

                            <Label Grid.Column="1"
                                   Text="{Binding MonthYearText}"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="#1E293B"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />

                            <Label Grid.Column="2" Text="▶"
                                   FontSize="20" TextColor="#64748B"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NextMonthCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <!-- Заглавия на дните -->
                        <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="2">
                            <Label Grid.Column="0" Text="Пн" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="Вт" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="Ср" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="Чт" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="Пт" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="Сб" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="6" Text="Нд" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                        </Grid>

                        <!-- Дни -->
                        <CollectionView ItemsSource="{Binding Days}"
                ItemsLayout="VerticalGrid, 7"
                HeightRequest="380"
                SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CalendarDayItem">
                                    <VerticalStackLayout Spacing="3"
                                 Padding="1"
                                 HorizontalOptions="Center"
                                 WidthRequest="46">
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarViewModel}}, Path=SelectDayCommand}"
                                          CommandParameter="{Binding .}" />
                                        </VerticalStackLayout.GestureRecognizers>

                                        <!-- Кръгче за калории -->
                                        <Grid WidthRequest="28" HeightRequest="28"
                      HorizontalOptions="Center"
                      IsVisible="{Binding HasCalories}">
                                            <!-- Фон кръг (сив) -->
                                            <Ellipse Fill="#E2E8F0"
                             WidthRequest="28" HeightRequest="28"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
                                            <!-- Запълнен кръг (зелен/червен) -->
                                            <Ellipse Fill="{Binding RingColor}"
                             WidthRequest="{Binding CaloriesProgress, Converter={StaticResource ProgressToSizeConverter}}"
                             HeightRequest="{Binding CaloriesProgress, Converter={StaticResource ProgressToSizeConverter}}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
                                        </Grid>

                                        <!-- Празно място ако няма калории -->
                                        <BoxView HeightRequest="28"
                         Color="Transparent"
                         IsVisible="{Binding HasCalories, Converter={StaticResource InvertBoolConverter}}" />

                                        <!-- Ден -->
                                        <Grid WidthRequest="30" HeightRequest="30"
                      HorizontalOptions="Center">
                                            <Ellipse Fill="{Binding DayBackgroundColor}"
                             WidthRequest="30" HeightRequest="30"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
                                            <Border StrokeShape="RoundRectangle 15"
                            Stroke="{Binding BorderColor}"
                            StrokeThickness="{Binding BorderThickness}"
                            BackgroundColor="Transparent"
                            WidthRequest="30" HeightRequest="30">
                                                <Label Text="{Binding DayNumber}"
                               FontSize="12"
                               TextColor="{Binding TextColor}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Информация за избрания ден -->
                <Border StrokeShape="RoundRectangle 16"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="16"
                        IsVisible="{Binding IsDayInfoVisible}">
                    <HorizontalStackLayout Spacing="10">
                        <Label Text="📊" FontSize="20" VerticalOptions="Center" />
                        <Label Text="{Binding SelectedDayInfo}"
                               FontSize="14"
                               TextColor="#1E293B"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- NavBar -->
        <components:NavBar Grid.Row="1" CurrentPage="calendar"/>
    </Grid>
</ContentPage>