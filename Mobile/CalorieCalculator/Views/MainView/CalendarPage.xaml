<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CalorieCalculator.ViewModels"
             xmlns:components="clr-namespace:CalorieCalculator.Views.MainView.Components"
             xmlns:converters="clr-namespace:CalorieCalculator.Converters"
             x:Class="CalorieCalculator.Views.CalendarPage"
             x:DataType="vm:CalendarViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <converters:ProgressToArcPathConverter x:Key="ProgressToArcPathConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Spacing="20" Padding="10,20">

                <Label Text="Калориен Календар"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#1E293B"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,25" />

                <Border StrokeShape="RoundRectangle 16"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="16">
                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*,Auto">
                            <Label Grid.Column="0" Text="◀"
                                   FontSize="20" TextColor="#64748B"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding PreviousMonthCommand}" />
                                </Label.GestureRecognizers>
                            </Label>

                            <Label Grid.Column="1"
                                   Text="{Binding MonthYearText}"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="#1E293B"
                                   HorizontalTextAlignment="Center"
                                   VerticalOptions="Center" />

                            <Label Grid.Column="2" Text="▶"
                                   FontSize="20" TextColor="#64748B"
                                   VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NextMonthCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*,*,*,*,*" ColumnSpacing="2" Margin="0,30,0,0">
                            <Label Grid.Column="0" Text="Пн" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="1" Text="Вт" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="2" Text="Ср" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="3" Text="Чт" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="4" Text="Пт" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="5" Text="Сб" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                            <Label Grid.Column="6" Text="Нд" FontSize="12" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                        </Grid>

                        <CollectionView ItemsSource="{Binding Days}"
                                        ItemsLayout="VerticalGrid, 7"
                                        HeightRequest="360"
                                        SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:CalendarDayItem">
                                    <VerticalStackLayout Spacing="0"
                             Padding="0"
                             HorizontalOptions="Center"
                             WidthRequest="50"
                             HeightRequest="50">
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CalendarViewModel}}, Path=SelectDayCommand}"
                                            CommandParameter="{Binding .}" />
                                        </VerticalStackLayout.GestureRecognizers>

                        <Grid WidthRequest="44" HeightRequest="44"
                            HorizontalOptions="Center"
                            VerticalOptions="Center">

                            <Ellipse Fill="{Binding DayBackgroundColor}"
                             WidthRequest="32" HeightRequest="32"
                             HorizontalOptions="Center" VerticalOptions="Center" />

                            <Ellipse WidthRequest="32" HeightRequest="32"
                            HorizontalOptions="Center" VerticalOptions="Center"
                            Fill="Transparent"
                            Stroke="{Binding SelectionRingColor}"
                            StrokeThickness="{Binding SelectionRingThickness}" />

                            <Ellipse WidthRequest="40" HeightRequest="40"
                            HorizontalOptions="Center" VerticalOptions="Center"
                            Fill="Transparent"
                            Stroke="#E2E8F0"
                            StrokeThickness="2.5"
                            IsVisible="{Binding ShowGrayRing}" />

                            <Path Stroke="{Binding CalorieRingColor}"
                              StrokeThickness="2.5"
                              StrokeLineCap="Round"
                              Fill="Transparent"
                              Data="{Binding ProgressForArc, Converter={StaticResource ProgressToArcPathConverter}, ConverterParameter='40,3'}"
                              WidthRequest="40" HeightRequest="40"
                              HorizontalOptions="Center" VerticalOptions="Center"
                              IsVisible="{Binding ShowCalorieRing}" />

                            <Label Text="{Binding DayNumber}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{Binding TextColor}"
                               HorizontalOptions="Center" VerticalOptions="Center" />   
                                        </Grid>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16"
                        Stroke="#E2E8F0"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        Padding="16"
                        IsVisible="{Binding IsDayInfoVisible}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding SelectedDayInfo}"
                               FontSize="14"
                               TextColor="#1E293B"
                               LineBreakMode="WordWrap"
                               HorizontalTextAlignment="Start"
                               VerticalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <components:NavBar Grid.Row="1" CurrentPage="calendar" x:Name="NavBar"/>
    </Grid>
</ContentPage>