<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalorieCalculator.Views.ProgressPage"
             BackgroundColor="#F5F6FA">

    <Grid RowDefinitions="*,Auto">

        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">
            <Label Text="Прогрес"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#1E293B"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Очаквайте скоро..."
                   FontSize="16"
                   TextColor="#94A3B8"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <Border Grid.Row="1"
                StrokeShape="RoundRectangle 0"
                Stroke="#E2E8F0"
                StrokeThickness="1"
                BackgroundColor="White"
                Padding="0"
                HeightRequest="56">
            <Grid ColumnDefinitions="*,*,*"
                  HorizontalOptions="Fill">

                <VerticalStackLayout Grid.Column="0"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnProfileTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="👤" FontSize="20" HorizontalTextAlignment="Center" />
                    <Label Text="Профил" FontSize="11"
                           TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTodayTapped" />
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="📅" FontSize="20" HorizontalTextAlignment="Center" />
                    <Label Text="Днес" FontSize="11"
                           TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="2">
                    <Label Text="📊" FontSize="20" HorizontalTextAlignment="Center" />
                    <Label Text="Прогрес" FontSize="11" FontAttributes="Bold"
                           TextColor="#22C55E" HorizontalTextAlignment="Center" />
                    <BoxView HeightRequest="2" WidthRequest="40"
                             Color="#22C55E" CornerRadius="1"
                             HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>
</ContentPage>