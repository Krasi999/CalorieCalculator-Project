<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:CalorieCalculator.Views.MainView.Components"
             x:Class="CalorieCalculator.Views.ProgressPage"
             BackgroundColor="#F5F6FA">

    <Grid RowDefinitions="*,Auto">

        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             HorizontalOptions="Center">
            <Label Text="Прогрес"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#1E293B"
                   HorizontalTextAlignment="Center"/>
            <Label Text="Очаквайте скоро..."
                   FontSize="16"
                   TextColor="#94A3B8"
                   HorizontalTextAlignment="Center"/>
        </VerticalStackLayout>

        <components:NavBar Grid.Row="1" CurrentPage="progress"/>
    </Grid>
</ContentPage>