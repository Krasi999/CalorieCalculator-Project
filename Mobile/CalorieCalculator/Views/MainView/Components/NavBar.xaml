<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalorieCalculator.Views.MainView.Components.NavBar">

    <Border StrokeShape="RoundRectangle 0"
        Stroke="#E2E8F0"
        StrokeThickness="1"
        BackgroundColor="White"
        Padding="0"
        HeightRequest="56">
        <Grid ColumnDefinitions="*,*,*,*"
          HorizontalOptions="Fill">

            <VerticalStackLayout Grid.Column="0"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="2">
                <Image Source="{Binding ProfileIcon}"
                   WidthRequest="24"
                   HeightRequest="24"
                   HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand}"
                                      CommandParameter="profile"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="2">
                <Image Source="{Binding HomeIcon}"
                   WidthRequest="24"
                   HeightRequest="24"
                   HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand}"
                                      CommandParameter="home"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="2">
                <Image Source="{Binding ProgressIcon}"
                   WidthRequest="24"
                   HeightRequest="24"
                   HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand}"
                                      CommandParameter="progress"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="3"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="2">
                <Image Source="{Binding CalendarIcon}"
                   WidthRequest="24"
                   HeightRequest="24"
                   HorizontalOptions="Center"/>
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand}"
                                      CommandParameter="calendar"/>
                </VerticalStackLayout.GestureRecognizers>
            </VerticalStackLayout>

        </Grid>
    </Border>

</ContentView>