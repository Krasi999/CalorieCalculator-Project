<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CalorieCalculator.ViewModels"
             xmlns:components="clr-namespace:CalorieCalculator.Views.MainView.Components"
             x:Class="CalorieCalculator.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0" x:Name="MainScroll">
            <VerticalStackLayout Spacing="12" Padding="16,12">

                <Label Text="Моят профил"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#1E293B"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,5" />

                <Border StrokeShape="RoundRectangle 20"
                        Stroke="#E2E8F0" StrokeThickness="1"
                        BackgroundColor="White" Padding="20">
                    <VerticalStackLayout Spacing="12" HorizontalOptions="Center">

                        <Grid WidthRequest="100" HeightRequest="100"
                            HorizontalOptions="Center">
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ChangePhotoCommand}" />
                            </Grid.GestureRecognizers>

                            <Ellipse Fill="{Binding ProfileColor}"
                                 WidthRequest="100" HeightRequest="100"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 IsVisible="{Binding HasProfileImage, Converter={StaticResource InvertBoolConverter}}" />
                            <Label Text="{Binding ProfileInitial}"
                                   FontSize="40"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   IsVisible="{Binding HasProfileImage, Converter={StaticResource InvertBoolConverter}}" />

                            <Border StrokeShape="RoundRectangle 50"
                                StrokeThickness="0"
                                WidthRequest="100"
                                HeightRequest="100"
                                HorizontalOptions="Center"
                                VerticalOptions="Center"
                                IsVisible="{Binding HasProfileImage}">
                                <Image Source="{Binding ProfileImage}"
                                   Aspect="AspectFill"
                                   WidthRequest="100"
                                   HeightRequest="100" />
                            </Border>

                            <Grid WidthRequest="32" HeightRequest="32"
                                 HorizontalOptions="End"
                                 VerticalOptions="End">
                                <Ellipse Fill="#F2F0EF"
                                     WidthRequest="32" HeightRequest="32"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center">
                                    <Ellipse.Shadow>
                                        <Shadow Brush="Black" Offset="0,1" Radius="2" Opacity="0.2" />
                                    </Ellipse.Shadow>
                                </Ellipse>
                                <Label Text="📷"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                            </Grid>
                        </Grid>

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8"
                                               IsVisible="{Binding IsEditingNickname, Converter={StaticResource InvertBoolConverter}}">
                            <Label Text="{Binding Nickname}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="#1E293B" VerticalOptions="Center" />
                            <Label Text="✏️" FontSize="16" VerticalOptions="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding StartEditNicknameCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </HorizontalStackLayout>

                        <VerticalStackLayout IsVisible="{Binding IsEditingNickname}"
                                             Spacing="8" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 10"
                                    Stroke="#CBD5E1" BackgroundColor="#F8FAFC"
                                    Padding="10,4" WidthRequest="200">
                                <Entry Text="{Binding EditNickname}"
                                       FontSize="16" TextColor="#1E293B"
                                       BackgroundColor="Transparent"
                                       HorizontalTextAlignment="Center" />
                            </Border>
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                                <Button Text="Запази" Command="{Binding SaveNicknameCommand}"
                                        FontSize="13" BackgroundColor="#22C55E" TextColor="White"
                                        CornerRadius="15" HeightRequest="34" Padding="15,0" />
                                <Button Text="Откажи" 
                                        Command="{Binding CancelEditNicknameCommand}"
                                        FontSize="13" BackgroundColor="#EF4444" TextColor="White"
                                        CornerRadius="15" HeightRequest="34" Padding="15,0" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>

                        <Label Text="{Binding ErrorMessage}"
                               TextColor="#EF4444" FontSize="12"
                               HorizontalTextAlignment="Center"
                               IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16"
                        Stroke="#E2E8F0" StrokeThickness="1"
                        BackgroundColor="White" Padding="16">
                    <VerticalStackLayout Spacing="12">

                        <Label Text="Детайли за профила"
                               FontSize="15" FontAttributes="Bold" TextColor="#1E293B" />

                        <BoxView HeightRequest="1" Color="#F1F5F9" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                            RowSpacing="12" ColumnSpacing="10" Padding="4">

                            <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                                <Label Text="Пол" FontSize="11" TextColor="#94A3B8" />
                                <Label Text="{Binding GenderText}" FontSize="14" FontAttributes="Bold" TextColor="#1E293B" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                                <Label Text="Възраст" FontSize="11" TextColor="#94A3B8" />
                                <Label Text="{Binding AgeText}" FontSize="14" FontAttributes="Bold" TextColor="#1E293B" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditHeightCommand}" />
                                </VerticalStackLayout.GestureRecognizers>
                                <Label Text="Ръст" FontSize="11" TextColor="#94A3B8" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding HeightText}" FontSize="14" FontAttributes="Bold" TextColor="#1E293B" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditWeightCommand}" />
                                </VerticalStackLayout.GestureRecognizers>
                                <Label Text="Тегло" FontSize="11" TextColor="#94A3B8" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding WeightText}" FontSize="14" FontAttributes="Bold" TextColor="#1E293B" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditActivityCommand}" />
                                </VerticalStackLayout.GestureRecognizers>
                                <Label Text="Активност" FontSize="11" TextColor="#94A3B8" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding ActivityText}" FontSize="14" FontAttributes="Bold"
                                          TextColor="#1E293B" LineBreakMode="WordWrap" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditGoalCommand}" />
                                </VerticalStackLayout.GestureRecognizers>
                                <Label Text="Цел" FontSize="11" TextColor="#94A3B8" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding GoalText}" FontSize="14" FontAttributes="Bold"
                                        TextColor="#1E293B" LineBreakMode="WordWrap" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EditTargetWeightCommand}" />
                                </VerticalStackLayout.GestureRecognizers>
                                <Label Text="Желано тегло" FontSize="11" TextColor="#94A3B8" />
                                <HorizontalStackLayout Spacing="4">
                                    <Label Text="{Binding TargetWeightText}" FontSize="14" FontAttributes="Bold" TextColor="#1E293B" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16"
                        Stroke="#E2E8F0" StrokeThickness="1"
                        BackgroundColor="White" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleBiometricCommand}" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Биометричен вход"
                                   FontSize="15" FontAttributes="Bold" TextColor="#1E293B" />
                            <Label Text="Пръстов отпечатък"
                                   FontSize="12" TextColor="#94A3B8" />
                        </VerticalStackLayout>

                        <Grid Grid.Column="1"
                              WidthRequest="52" HeightRequest="30"
                              VerticalOptions="Center">
                            <Border StrokeShape="RoundRectangle 15"
                                    StrokeThickness="0"
                                    BackgroundColor="{Binding IsBiometricEnabled, Converter={StaticResource BoolToSwitchColorConverter}}"
                                    WidthRequest="52" HeightRequest="30"
                                    HorizontalOptions="Fill" VerticalOptions="Center" />
                            <Ellipse Fill="White"
                                     WidthRequest="24" HeightRequest="24"
                                     HorizontalOptions="{Binding IsBiometricEnabled, Converter={StaticResource BoolToThumbAlignConverter}}"
                                     VerticalOptions="Center"
                                     Margin="{Binding IsBiometricEnabled, Converter={StaticResource BoolToThumbMarginConverter}}">
                                <Ellipse.Shadow>
                                    <Shadow Brush="Black" Offset="0,1" Radius="3" Opacity="0.25" />
                                </Ellipse.Shadow>
                            </Ellipse>
                        </Grid>
                    </Grid>
                </Border>

                <Border StrokeShape="RoundRectangle 16"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    BackgroundColor="White" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnAboutTapped" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="За приложението"
                   FontSize="15" FontAttributes="Bold" TextColor="#1E293B" />
                        </VerticalStackLayout>
                        <Label Grid.Column="1"
               Text="{Binding IsAboutVisible, Converter={StaticResource BoolToChevronConverter}}"
               FontSize="22" TextColor="#94A3B8" VerticalOptions="Center" />
                    </Grid>
                </Border>

                <Border IsVisible="{Binding IsAboutVisible}"
                    StrokeShape="RoundRectangle 16"
                    Stroke="#E2E8F0" StrokeThickness="1"
                    BackgroundColor="White"
                    Padding="0">
                    <VerticalStackLayout Padding="20" Spacing="16">

                        <VerticalStackLayout Spacing="4">
                            <Label Text="Калориен калкулатор"
                                  FontSize="16" FontAttributes="Bold" TextColor="#1E40AF" />
                            <Label Text="Твоят интелигентен хранителен дневник"
                                 FontSize="12" TextColor="#94A3B8" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1" Color="#E2E8F0" />

                        <VerticalStackLayout Spacing="12">

                            <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0" BackgroundColor="#DBEAFE"
                                    WidthRequest="36" HeightRequest="36">
                                    <Label Text="🔥" FontSize="16"
                                        HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Проследяване на калории"
                                         FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                                    <Label Text="Следи дневния си прием и оставащите калории в реално време."
                                        FontSize="11" TextColor="#64748B" />
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0" BackgroundColor="#D1FAE5"
                                    WidthRequest="36" HeightRequest="36">
                                    <Label Text="📷" FontSize="16"
                                        HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Сканиране на баркод"
                                        FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                                    <Label Text="Насочи камерата към продукт и получи хранителната информация мигновено."
                                        FontSize="11" TextColor="#64748B" />
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0" BackgroundColor="#FEF3C7"
                                    WidthRequest="36" HeightRequest="36">
                                    <Label Text="🎯" FontSize="16"
                                         HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Персонализирани цели"
                                        FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                                    <Label Text="Отслабване, поддържане или качване на тегло — планът се адаптира към теб."
                                        FontSize="11" TextColor="#64748B" />
                                </VerticalStackLayout>
                            </Grid>

                            <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                                <Border Grid.Column="0" StrokeShape="RoundRectangle 10"
                                    StrokeThickness="0" BackgroundColor="#EDE9FE"
                                     WidthRequest="36" HeightRequest="36">
                                    <Label Text="🔐" FontSize="16"
                                        HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="Биометрична сигурност"
                                        FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                                    <Label Text="Влизай бързо и сигурно с пръстов отпечатък или Face ID."
                                        FontSize="11" TextColor="#64748B" />
                                </VerticalStackLayout>
                            </Grid>

                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 16"
                        Stroke="#FEE2E2" StrokeThickness="1"
                        BackgroundColor="#FEF2F2" Padding="16" Margin="0,8,0,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Label Text="Изход от акаунта"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="#EF4444" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <BoxView HeightRequest="0.1" Color="Transparent" />
            </VerticalStackLayout>
        </ScrollView>

        <components:NavBar Grid.Row="1" CurrentPage="profile" x:Name="NavBar"/>
    </Grid>
</ContentPage>