<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CalorieCalculator.ViewModels"
             x:Class="CalorieCalculator.Views.ForgotPasswordPage"
             x:DataType="vm:ForgotPasswordViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F4F8">

    <ScrollView VerticalOptions="Center">
        <VerticalStackLayout
            Padding="35,20"
            Spacing="0"
            MaximumWidthRequest="420"
            HorizontalOptions="Center">

            <!-- Back -->
            <Label Text="←  Назад"
                   FontSize="16"
                   TextColor="#3DB89E"
                   FontAttributes="Bold"
                   Margin="0,0,0,15">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Logo -->
            <Grid HeightRequest="85"
                  WidthRequest="85"
                  HorizontalOptions="Center"
                  Margin="0,0,0,14">
                <Ellipse Fill="#C8E6DF"
                         WidthRequest="85"
                         HeightRequest="85"
                         HorizontalOptions="Center"
                         VerticalOptions="Center" />
                <Label Text="🔑"
                       FontSize="40"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Grid>

            <Label Text="Възстановяване на парола"
                   FontSize="22"
                   FontAttributes="Bold"
                   TextColor="#1C1C1E"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,12" />

            <!-- Step progress bar -->
            <Grid ColumnDefinitions="*,8,*,8,*"
                  Margin="50,10,50,28"
                  HeightRequest="4">
                <BoxView Grid.Column="0" Color="#3DB89E" CornerRadius="2" />
                <BoxView Grid.Column="2"
                         Color="{Binding IsStep1Visible, Converter={StaticResource BoolToStepInactiveConverter}}"
                         CornerRadius="2" />
                <BoxView Grid.Column="4"
                         Color="{Binding IsStep3Visible, Converter={StaticResource BoolToStepColorConverter}}"
                         CornerRadius="2" />
            </Grid>

            <!-- Step 1 -->
            <VerticalStackLayout IsVisible="{Binding IsStep1Visible}" Spacing="0">

                <Label Text="Стъпка 1 от 3"
                       FontSize="12"
                       TextColor="#3DB89E"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,8" />

                <Label Text="Въведи имейла, с който си се регистрирал."
                       FontSize="13"
                       TextColor="#AEAEB2"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,28" />

                <Label Text="Имейл"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#6B7280"
                       Margin="4,0,0,6" />

                <Border StrokeShape="RoundRectangle 14"
                        Stroke="#E5E7EB"
                        BackgroundColor="White"
                        Padding="14,2"
                        Margin="0,0,0,18">
                    <Entry Text="{Binding Email}"
                           Placeholder="example@mail.com"
                           PlaceholderColor="#C7C7CC"
                           TextColor="#1C1C1E"
                           Keyboard="Email"
                           FontSize="15"
                           BackgroundColor="Transparent" />
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#EF4444"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                       Margin="0,0,0,10" />

                <Button Text="Изпрати код"
                        Command="{Binding RequestCodeCommand}"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="White"
                        BackgroundColor="#3DB89E"
                        CornerRadius="25"
                        HeightRequest="52"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
            </VerticalStackLayout>

            <!-- Step 2 -->
            <VerticalStackLayout IsVisible="{Binding IsStep2Visible}" Spacing="0">

                <Label Text="Стъпка 2 от 3"
                       FontSize="12"
                       TextColor="#3DB89E"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,8" />

                <Label Text="Въведи 6-цифрения код за възстановяване."
                       FontSize="13"
                       TextColor="#AEAEB2"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,25" />

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="6"
                                       Margin="0,0,0,20">
                    <Label Text="⏱"
                           FontSize="16"
                           VerticalOptions="Center" />
                    <Label Text="{Binding TimerText}"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="{Binding IsTimerExpired, Converter={StaticResource BoolToTimerColorConverter}}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- 6-digit code input -->
                <Grid ColumnDefinitions="*,*,*,*,*,*"
                      ColumnSpacing="8"
                      Margin="0,0,0,20"
                      HorizontalOptions="Center"
                      WidthRequest="310">

                    <Border Grid.Column="0" StrokeShape="RoundRectangle 12"
                            Stroke="#E5E7EB" BackgroundColor="White"
                            HeightRequest="55" Padding="0">
                        <Entry x:Name="Entry1"
                               Text="{Binding Digit1}"
                               MaxLength="1" Keyboard="Numeric"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#1C1C1E"
                               HorizontalTextAlignment="Center"
                               BackgroundColor="Transparent"
                               TextChanged="OnDigitTextChanged" />
                    </Border>

                    <Border Grid.Column="1" StrokeShape="RoundRectangle 12"
                            Stroke="#E5E7EB" BackgroundColor="White"
                            HeightRequest="55" Padding="0">
                        <Entry x:Name="Entry2"
                               Text="{Binding Digit2}"
                               MaxLength="1" Keyboard="Numeric"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#1C1C1E"
                               HorizontalTextAlignment="Center"
                               BackgroundColor="Transparent"
                               TextChanged="OnDigitTextChanged" />
                    </Border>

                    <Border Grid.Column="2" StrokeShape="RoundRectangle 12"
                            Stroke="#E5E7EB" BackgroundColor="White"
                            HeightRequest="55" Padding="0">
                        <Entry x:Name="Entry3"
                               Text="{Binding Digit3}"
                               MaxLength="1" Keyboard="Numeric"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#1C1C1E"
                               HorizontalTextAlignment="Center"
                               BackgroundColor="Transparent"
                               TextChanged="OnDigitTextChanged" />
                    </Border>

                    <Border Grid.Column="3" StrokeShape="RoundRectangle 12"
                            Stroke="#E5E7EB" BackgroundColor="White"
                            HeightRequest="55" Padding="0">
                        <Entry x:Name="Entry4"
                               Text="{Binding Digit4}"
                               MaxLength="1" Keyboard="Numeric"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#1C1C1E"
                               HorizontalTextAlignment="Center"
                               BackgroundColor="Transparent"
                               TextChanged="OnDigitTextChanged" />
                    </Border>

                    <Border Grid.Column="4" StrokeShape="RoundRectangle 12"
                            Stroke="#E5E7EB" BackgroundColor="White"
                            HeightRequest="55" Padding="0">
                        <Entry x:Name="Entry5"
                               Text="{Binding Digit5}"
                               MaxLength="1" Keyboard="Numeric"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#1C1C1E"
                               HorizontalTextAlignment="Center"
                               BackgroundColor="Transparent"
                               TextChanged="OnDigitTextChanged" />
                    </Border>

                    <Border Grid.Column="5" StrokeShape="RoundRectangle 12"
                            Stroke="#E5E7EB" BackgroundColor="White"
                            HeightRequest="55" Padding="0">
                        <Entry x:Name="Entry6"
                               Text="{Binding Digit6}"
                               MaxLength="1" Keyboard="Numeric"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#1C1C1E"
                               HorizontalTextAlignment="Center"
                               BackgroundColor="Transparent"
                               TextChanged="OnDigitTextChanged" />
                    </Border>
                </Grid>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#EF4444"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                       Margin="0,0,0,10" />

                <Button Text="Потвърди код"
                        Command="{Binding VerifyCodeCommand}"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="White"
                        BackgroundColor="#3DB89E"
                        CornerRadius="25"
                        HeightRequest="52"
                        Margin="0,0,0,15"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="5">
                    <Label Text="Не получи код?"
                           TextColor="#AEAEB2"
                           FontSize="13" />
                    <Label Text="Изпрати нов"
                           TextColor="#3DB89E"
                           FontSize="13"
                           FontAttributes="Bold"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ResendCodeCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Step 3 -->
            <VerticalStackLayout IsVisible="{Binding IsStep3Visible}" Spacing="0">

                <Label Text="Стъпка 3 от 3"
                       FontSize="12"
                       TextColor="#3DB89E"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,8" />

                <Label Text="Задай нова парола за своя акаунт."
                       FontSize="13"
                       TextColor="#AEAEB2"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,25" />

                <Label Text="Нова парола"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#6B7280"
                       Margin="4,0,0,6" />

                <Border StrokeShape="RoundRectangle 14"
                        Stroke="#E5E7EB"
                        BackgroundColor="White"
                        Padding="14,2"
                        Margin="0,0,0,10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry Grid.Column="0"
                               Text="{Binding NewPassword}"
                               Placeholder="••••••••"
                               PlaceholderColor="#C7C7CC"
                               TextColor="#1C1C1E"
                               IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertBoolConverter}}"
                               FontSize="15"
                               BackgroundColor="Transparent" />
                        <Label Grid.Column="1"
                               Text="{Binding IsPasswordVisible, Converter={StaticResource BoolToEyeIconConverter}}"
                               FontSize="18"
                               TextColor="#AEAEB2"
                               VerticalOptions="Center"
                               Margin="0,0,10,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Password requirements -->
                <VerticalStackLayout Margin="4,2,0,18" Spacing="4">
                    <Label FontSize="11" TextColor="#3DB89E" FontAttributes="Bold"
                           Text="Изисквания за паролата (ISO/IEC 27001):" />

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="{Binding HasMinLength, Converter={StaticResource BoolToIconConverter}}"
                               FontSize="11"
                               TextColor="{Binding HasMinLength, Converter={StaticResource BoolToColorConverter}}" />
                        <Label Text="Минимум 8 символа" FontSize="11"
                               TextColor="{Binding HasMinLength, Converter={StaticResource BoolToColorConverter}}" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="{Binding HasUpperCase, Converter={StaticResource BoolToIconConverter}}"
                               FontSize="11"
                               TextColor="{Binding HasUpperCase, Converter={StaticResource BoolToColorConverter}}" />
                        <Label Text="Главна буква (A-Z)" FontSize="11"
                               TextColor="{Binding HasUpperCase, Converter={StaticResource BoolToColorConverter}}" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="{Binding HasLowerCase, Converter={StaticResource BoolToIconConverter}}"
                               FontSize="11"
                               TextColor="{Binding HasLowerCase, Converter={StaticResource BoolToColorConverter}}" />
                        <Label Text="Малка буква (a-z)" FontSize="11"
                               TextColor="{Binding HasLowerCase, Converter={StaticResource BoolToColorConverter}}" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="{Binding HasDigit, Converter={StaticResource BoolToIconConverter}}"
                               FontSize="11"
                               TextColor="{Binding HasDigit, Converter={StaticResource BoolToColorConverter}}" />
                        <Label Text="Цифра (0-9)" FontSize="11"
                               TextColor="{Binding HasDigit, Converter={StaticResource BoolToColorConverter}}" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="{Binding HasSpecialChar, Converter={StaticResource BoolToIconConverter}}"
                               FontSize="11"
                               TextColor="{Binding HasSpecialChar, Converter={StaticResource BoolToColorConverter}}" />
                        <Label Text="Специален символ (!@#$...)" FontSize="11"
                               TextColor="{Binding HasSpecialChar, Converter={StaticResource BoolToColorConverter}}" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <Label Text="Потвърди паролата"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#6B7280"
                       Margin="4,0,0,6" />

                <Border StrokeShape="RoundRectangle 14"
                        Stroke="#E5E7EB"
                        BackgroundColor="White"
                        Padding="14,2"
                        Margin="0,0,0,28">
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry Grid.Column="0"
                               Text="{Binding ConfirmPassword}"
                               Placeholder="••••••••"
                               PlaceholderColor="#C7C7CC"
                               TextColor="#1C1C1E"
                               IsPassword="{Binding IsConfirmPasswordVisible, Converter={StaticResource InvertBoolConverter}}"
                               FontSize="15"
                               BackgroundColor="Transparent" />
                        <Label Grid.Column="1"
                               Text="{Binding IsConfirmPasswordVisible, Converter={StaticResource BoolToEyeIconConverter}}"
                               FontSize="18"
                               TextColor="#AEAEB2"
                               VerticalOptions="Center"
                               Margin="0,0,10,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleConfirmPasswordVisibilityCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#EF4444"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                       Margin="0,0,0,10" />

                <Button Text="Смени паролата"
                        Command="{Binding ResetPasswordCommand}"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="White"
                        BackgroundColor="#3DB89E"
                        CornerRadius="25"
                        HeightRequest="52"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#3DB89E"
                               HeightRequest="30"
                               Margin="0,15,0,10" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>