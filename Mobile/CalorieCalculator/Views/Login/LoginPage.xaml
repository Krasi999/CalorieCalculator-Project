<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CalorieCalculator.ViewModels"
             x:Class="CalorieCalculator.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Transparent">

    <!-- Gradient Background -->
    <Grid>
        <BoxView>
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A1F3D" Offset="0.0" />
                    <GradientStop Color="#153A6B" Offset="0.3" />
                    <GradientStop Color="#2563EB" Offset="0.6" />
                    <GradientStop Color="#3B82F6" Offset="0.85" />
                    <GradientStop Color="#93C5FD" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout
                Padding="35,20"
                Spacing="0"
                MaximumWidthRequest="420"
                HorizontalOptions="Center">

                <!-- Logo / Icon -->
                <Grid HeightRequest="100"
                      WidthRequest="100"
                      HorizontalOptions="Center"
                      Margin="0,0,0,10">
                    <Ellipse Fill="#FFFFFF20"
                             WidthRequest="100"
                             HeightRequest="100"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
                    <Label Text="🔥"
                           FontSize="48"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>

                <!-- App Name -->
                <Label Text="CalorieTracker"
                       FontSize="28"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,5" />

                <Label Text="Твоят персонален хранителен дневник"
                       FontSize="13"
                       TextColor="#BFDBFE"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,35" />

                <!-- Title -->
                <Label Text="Вход"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,25" />

                <!-- Email Field -->
                <Label Text="Имейл"
                       FontSize="13"
                       TextColor="#BFDBFE"
                       Margin="5,0,0,6" />

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="#FFFFFF40"
                        BackgroundColor="White"
                        Padding="14,2"
                        Margin="0,0,0,18">
                    <Entry Text="{Binding Email}"
                           Placeholder="example@mail.com"
                           PlaceholderColor="#94A3B8"
                           TextColor="#0F172A"
                           Keyboard="Email"
                           FontSize="15"
                           BackgroundColor="Transparent" />
                </Border>

                <!-- Password Field -->
                <Label Text="Парола"
                       FontSize="13"
                       TextColor="#BFDBFE"
                       Margin="5,0,0,6" />

                <Border StrokeShape="RoundRectangle 12"
        Stroke="#FFFFFF40"
        BackgroundColor="White"
        Padding="14,2"
        Margin="0,0,0,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry Grid.Column="0"
               Text="{Binding Password}"
               Placeholder="••••••••"
               PlaceholderColor="#94A3B8"
               TextColor="#0F172A"
               IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertBoolConverter}}"
               FontSize="15"
               BackgroundColor="Transparent" />
                        <Label Grid.Column="1"
               Text="{Binding IsPasswordVisible, Converter={StaticResource BoolToEyeIconConverter}}"
               FontSize="18"
               TextColor="#64748B"
               VerticalOptions="Center"
               Margin="0,0,10,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <!-- Remember Me & Forgot Password Row -->
                <Grid Margin="0,0,0,25"
                      ColumnDefinitions="*,Auto">

                    <HorizontalStackLayout Grid.Column="0"
                                           Spacing="6"
                                           VerticalOptions="Center">
                        <CheckBox Color="#3B82F6"
                                  IsChecked="{Binding RememberMe}"
                                  VerticalOptions="Center"
                                  Scale="0.85" />
                        <Label Text="Запомни ме"
                               TextColor="#BFDBFE"
                               FontSize="12"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Grid.Column="1"
                           Text="Забравена парола?"
                           TextColor="#93C5FD"
                           FontSize="12"
                           FontAttributes="Bold"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <!-- Error Message -->
                <Label Text="{Binding ErrorMessage}"
                       TextColor="#FCA5A5"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                       Margin="0,0,0,10" />

                <!-- Login Button -->
                <Button Text="Вход"
                        Command="{Binding LoginCommand}"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="#0A1F3D"
                        BackgroundColor="White"
                        CornerRadius="25"
                        HeightRequest="52"
                        Margin="0,0,0,15"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                <!-- Loading Indicator -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="White"
                                   HeightRequest="30"
                                   Margin="0,0,0,10" />

                <!-- Biometric Login Button -->
                <Border StrokeShape="RoundRectangle 25"
                        Stroke="#FFFFFF40"
                        BackgroundColor="#FFFFFF10"
                        HeightRequest="52"
                        Margin="0,0,0,20"
                        IsVisible="{Binding IsBiometricAvailable}">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding BiometricLoginCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Spacing="10">
                        <Label Text="🔐"
                               FontSize="20"
                               VerticalOptions="Center" />
                        <Label Text="Вход с биометрия"
                               TextColor="White"
                               FontSize="15"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- Divider -->
                <Grid ColumnDefinitions="*,Auto,*"
                      Margin="0,0,0,20">
                    <BoxView Grid.Column="0"
                             HeightRequest="1"
                             Color="#FFFFFF30"
                             VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="или"
                           TextColor="#93C5FD"
                           FontSize="12"
                           Margin="15,0" />
                    <BoxView Grid.Column="2"
                             HeightRequest="1"
                             Color="#FFFFFF30"
                             VerticalOptions="Center" />
                </Grid>

                <!-- Register Link -->
                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="5"
                                       Margin="0,0,0,20">
                    <Label Text="Нямаш акаунт?"
                           TextColor="#BFDBFE"
                           FontSize="14" />
                    <Label Text="Регистрирай се"
                           TextColor="White"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>