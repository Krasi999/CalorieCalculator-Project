<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CalorieCalculator.ViewModels"
             x:Class="CalorieCalculator.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F4F8">

    <Grid>

        <!-- Основно съдържание -->
        <ScrollView VerticalOptions="Center"
                    HorizontalOptions="Fill">
            <VerticalStackLayout
                Padding="0"
                Margin="30,40"
                Spacing="0"
                HorizontalOptions="Fill">

                <Grid HeightRequest="90"
                      WidthRequest="90"
                      HorizontalOptions="Center"
                      Margin="0,0,0,14">
                    <Ellipse Fill="#C8E6DF"
                             WidthRequest="90"
                             HeightRequest="90"
                             HorizontalOptions="Center"
                             VerticalOptions="Center" />
                    <Label Text="🔥"
                           FontSize="42"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Grid>

                <Label Text="CalorieTracker"
                       FontSize="26"
                       FontAttributes="Bold"
                       TextColor="#1C1C1E"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,5" />

                <Label Text="Твоят персонален хранителен дневник"
                       FontSize="13"
                       TextColor="#AEAEB2"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,36" />

                <Label Text="Вход"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1C1C1E"
                       HorizontalTextAlignment="Center"
                       Margin="0,0,0,28" />

                <Label Text="Имейл"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#6B7280"
                       Margin="4,0,0,6" />

                <Border StrokeShape="RoundRectangle 14"
                        Stroke="#E5E7EB"
                        BackgroundColor="White"
                        Padding="14,2"
                        Margin="0,0,0,18">
                    <Entry Text="{Binding Email}"
                           Placeholder="example@mail.com"
                           PlaceholderColor="#C7C7CC"
                           TextColor="#1C1C1E"
                           Keyboard="Email"
                           FontSize="15"
                           BackgroundColor="Transparent" />
                </Border>

                <Label Text="Парола"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#6B7280"
                       Margin="4,0,0,6" />

                <Border StrokeShape="RoundRectangle 14"
                        Stroke="#E5E7EB"
                        BackgroundColor="White"
                        Padding="14,2"
                        Margin="0,0,0,10">
                    <Grid ColumnDefinitions="*,Auto">
                        <Entry Grid.Column="0"
                               Text="{Binding Password}"
                               Placeholder="••••••••"
                               PlaceholderColor="#C7C7CC"
                               TextColor="#1C1C1E"
                               IsPassword="{Binding IsPasswordVisible, Converter={StaticResource InvertBoolConverter}}"
                               FontSize="15"
                               BackgroundColor="Transparent" />
                        <Label Grid.Column="1"
                               Text="{Binding IsPasswordVisible, Converter={StaticResource BoolToEyeIconConverter}}"
                               FontSize="18"
                               TextColor="#AEAEB2"
                               VerticalOptions="Center"
                               Margin="0,0,10,0">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TogglePasswordVisibilityCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Grid>
                </Border>

                <Grid Margin="0,0,0,28"
                      ColumnDefinitions="*,Auto">
                    <HorizontalStackLayout Grid.Column="0"
                                           Spacing="6"
                                           VerticalOptions="Center">
                        <CheckBox Color="#3DB89E"
                                  IsChecked="{Binding RememberMe}"
                                  VerticalOptions="Center"
                                  Scale="0.85" />
                        <Label Text="Запомни ме"
                               TextColor="#6B7280"
                               FontSize="12"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Grid.Column="1"
                           Text="Забравена парола?"
                           TextColor="#3DB89E"
                           FontSize="12"
                           FontAttributes="Bold"
                           VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ForgotPasswordCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </Grid>

                <Label Text="{Binding ErrorMessage}"
                       TextColor="#EF4444"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                       Margin="0,0,0,10" />

                <Button Text="Вход"
                        Command="{Binding LoginCommand}"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="White"
                        BackgroundColor="#3DB89E"
                        CornerRadius="25"
                        HeightRequest="52"
                        Margin="0,0,0,14"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}" />

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="#3DB89E"
                                   HeightRequest="30"
                                   Margin="0,0,0,10" />

                <Grid ColumnDefinitions="*,Auto,*"
                      Margin="0,0,0,20">
                    <BoxView Grid.Column="0"
                             HeightRequest="1"
                             Color="#E5E7EB"
                             VerticalOptions="Center" />
                    <Label Grid.Column="1"
                           Text="или"
                           TextColor="#AEAEB2"
                           FontSize="12"
                           Margin="15,0" />
                    <BoxView Grid.Column="2"
                             HeightRequest="1"
                             Color="#E5E7EB"
                             VerticalOptions="Center" />
                </Grid>

                <HorizontalStackLayout HorizontalOptions="Center"
                                       Spacing="5"
                                       Margin="0,0,0,20">
                    <Label Text="Нямаш акаунт?"
                           TextColor="#AEAEB2"
                           FontSize="14" />
                    <Label Text="Регистрирай се"
                           TextColor="#3DB89E"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextDecorations="Underline">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                        </Label.GestureRecognizers>
                    </Label>
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>