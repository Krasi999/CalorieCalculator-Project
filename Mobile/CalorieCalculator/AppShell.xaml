<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CalorieCalculator.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CalorieCalculator.Views"
    xmlns:local="clr-namespace:CalorieCalculator"
    Title="CalorieCalculator"
    Shell.FlyoutBehavior="Disabled"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <ShellContent Title="Вход"
                  ContentTemplate="{DataTemplate views:LoginPage}"
                  Route="Login" />

    <ShellContent Title="Регистрация"
                  ContentTemplate="{DataTemplate views:RegisterPage}"
                  Route="Register" />

    <ShellContent Title="Забравена парола"
                  ContentTemplate="{DataTemplate views:ForgotPasswordPage}"
                  Route="ForgotPassword" />

    <ShellContent Title="Профил настройка"
                  ContentTemplate="{DataTemplate views:ProfileSetupPage}"
                  Route="ProfileSetup" />

    <ShellContent Route="ProfilePage"
                  ContentTemplate="{DataTemplate views:ProfilePage}" />

    <ShellContent Route="MainPage"
                  ContentTemplate="{DataTemplate views:MainPage}" />

    <ShellContent Route="ProgressPage"
                  ContentTemplate="{DataTemplate views:ProgressPage}" />
</Shell>